# Copy this file to tests/.env and fill in your Perforce details.
# Integration tests will be skipped if tests/.env is missing.

P4_ROOT=/path/to/workspace
P4_USER=your.username
P4_CLIENT=your-workspace-name
P4_SERVER=ssl:perforce.example.com:1666
TEST_DEPOT_FOLDER=//depot/path/to/test/folder
TEST_LOCAL_FOLDER=/path/to/workspace/test/folder
